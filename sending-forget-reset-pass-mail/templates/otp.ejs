<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Email Verification OTP</title>
</head>
<body style="font-family: Arial, sans-serif; margin: 0; padding: 0; background-color: #f4f4f4;">
    <div style="width: 100%; max-width: 600px; margin: 0 auto; padding: 20px; background-color: #ffffff; border-radius: 8px; box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);">
        
        <div style="text-align: center; margin-bottom: 20px;">
            <h2 style="color: #333;">RESET PASSWORD Verification OTP</h2>
        </div>

        <h2 style="color: #333;">Hi <%= userName %> </h2>
        
        <div style="margin-bottom: 20px;">
            <p style="color: #555; font-size: 16px;">Your One-Time Password (OTP) for resetting the password:</p>
            
            <table style="width: 100%; border-collapse: separate; border-spacing: 0; margin-bottom: 20px; background-color: #ffffff; border: 2px dashed #333333; border-radius: 6px;">
                <tr>
                    <td style="border-radius: 6px 6px 0 0; background-color: #f9f9f9; padding: 20px;">
                        <div style="font-size: 32px; font-weight: bold; text-align: center; color: #007bff; letter-spacing: 5px;">
                            <%= otp %>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td style="border-radius: 0 0 6px 6px; background-color: #f9f9f9; padding: 10px; border-top: 1px solid #eee;">
                        <p style="font-size: 14px; color: #666666; text-align: center; margin: 0;">
                            This code will expire shortly. Please use this OTP to reset your password.
                        </p>
                    </td>
                </tr>
            </table>
            
            <p style="font-size: 12px; color: #999; text-align: center;">
                If you did not request a password reset, please ignore this email.
            </p>
        </div>
    </div>
</body>
</html>